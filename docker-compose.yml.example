services:
  wenku8:
    image: your-dockerhub-username/wenku8:latest
    container_name: wenku8
    environment:
      # 必填：wenku8 登录后的整行 Cookie
      WENKU_COOKIES: ${WENKU_COOKIES}
      # 可选：仅在使用 steel 模式时需要
      STEEL_API_KEY: ${STEEL_API_KEY:-}
      # steel / playwright / requests（推荐 steel）
      SCRAPER: ${SCRAPER:-steel}
      # 6 小时 = 21600 秒
      RUN_INTERVAL_SECONDS: ${RUN_INTERVAL_SECONDS:-21600}
      # 是否自动下载蓝奏合集（true/false）
      ENABLE_LANZOU_DOWNLOAD: ${ENABLE_LANZOU_DOWNLOAD:-false}
      PYTHONUNBUFFERED: "1"
    volumes:
      - ./out:/app/out
      - ./docs:/app/docs
    command: ["sh", "/app/run_scheduler.sh"]
    restart: unless-stopped
